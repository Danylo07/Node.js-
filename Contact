<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Контакти</title>
  <style>
    :root {
      --bg: #0c0c0d;
      --surface: #141416;
      --border: #222226;
      --accent: #47ffb2;
      --text: #f0f0ee;
      --muted: #555560;
      --font: "DM Mono", "Courier New", monospace;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 40px 24px;
    }

    .page { max-width: 620px; width: 100%; }

    .badge {
      display: inline-block;
      font-size: 10px;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--muted);
      border: 1px solid var(--border);
      padding: 4px 10px;
      border-radius: 2px;
      margin-bottom: 28px;
    }

    h1 {
      font-size: clamp(48px, 10vw, 80px);
      font-weight: 800;
      line-height: 0.9;
      letter-spacing: -0.03em;
      margin-bottom: 28px;
    }

    h1 span { color: var(--accent); }

    .contacts {
      list-style: none;
      border-top: 1px solid var(--border);
      margin-bottom: 40px;
    }

    .contacts li {
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid var(--border);
      padding: 16px 0;
      font-size: 13px;
    }

    .contacts .label { color: var(--muted); font-size: 11px; letter-spacing: 0.1em; }
    .contacts .value { color: var(--text); }
    .contacts a { color: var(--accent); text-decoration: none; }
    .contacts a:hover { opacity: 0.8; }

    nav { display: flex; gap: 12px; }

    nav a {
      font-size: 12px;
      letter-spacing: 0.08em;
      text-decoration: none;
      padding: 10px 20px;
      border-radius: 2px;
      transition: 0.15s ease;
    }

    nav a.primary {
      background: var(--accent);
      color: #0c0c0d;
      font-weight: 500;
    }

    nav a.secondary {
      border: 1px solid var(--border);
      color: var(--muted);
    }

    nav a:hover { opacity: 0.8; }

    .divider {
      width: 40px;
      height: 1px;
      background: var(--border);
      margin: 40px 0;
    }

    .meta { font-size: 11px; color: var(--muted); letter-spacing: 0.08em; }
  </style>
</head>
<body>
  <div class="page">
    <div class="badge">Node.js · http · fs</div>

    <h1>Кон<span>.</span><br/>так<span>.</span><br/>ти<span>.</span></h1>

    <ul class="contacts">
      <li>
        <span class="label">EMAIL</span>
        <span class="value"><a href="mailto:hello@example.com">hello@example.com</a></span>
      </li>
      <li>
        <span class="label">GITHUB</span>
        <span class="value"><a href="https://github.com" target="_blank">github.com/username</a></span>
      </li>
      <li>
        <span class="label">TELEGRAM</span>
        <span class="value"><a href="https://t.me/username" target="_blank">@username</a></span>
      </li>
      <li>
        <span class="label">LOCATION</span>
        <span class="value">Україна</span>
      </li>
    </ul>

    <nav>
      <a href="/contact" class="primary">/ contact</a>
      <a href="/home"    class="secondary">/ home</a>
    </nav>

    <div class="divider"></div>

    <p class="meta">
      GET /contact → 200 OK · Content-Type: text/html
    </p>
  </div>
</body>
</html>
